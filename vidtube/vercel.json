{
  "version": 2,
  "builds": [
    {
      "src": "api.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/healthcheck",
      "dest": "/api.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/api/v1/videos(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/api/v1/tweets(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/api/v1/subscriptions(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/api/v1/comments(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/api/v1/likes(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/api/v1/playlists(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
